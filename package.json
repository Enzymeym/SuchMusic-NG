{
  "name": "such-pc-ng",
  "version": "0.1.0-beta-ui",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:unit": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "electron:generate-icons": "electron-icon-builder --input=./resources/icon.png --output=build --flatten"
  },
  "dependencies": {
    "@applemusic-like-lyrics/amll-lyric": "link:packages/amll-lyric/pkg",
    "@applemusic-like-lyrics/vue": "^0.2.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "axios": "^1.13.5",
    "electron-icon-builder": "^2.0.1",
    "electron-updater": "^6.3.9",
    "flac-metadata": "^0.1.1",
    "highlight.js": "^11.11.1",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "mingcute_icon": "^2.9.71",
    "music-metadata": "^9.0.3",
    "naive-ui": "^2.43.2",
    "node-id3": "^0.2.9",
    "pinia": "^3.0.4",
    "suth-lyric-kit": "link:packages\\suth-lyric-kit",
    "vue-router": "^4.6.4",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^2.1.4",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
